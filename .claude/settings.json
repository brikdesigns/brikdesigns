{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/worktree-check.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/session-guard.sh",
            "timeout": 5
          },
          { "type": "command", "command": ".claude/hooks/worktree-check.sh" }
        ]
      }
    ]
  },
  "mcpServers": {
    "storybook-mcp": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless"]
    },
    "notion-brik": {
      "command": "bash",
      "args": ["-c", "set -a; source ~/.secrets/notion.env; set +a; NOTION_API_TOKEN=$NOTION_TOKEN exec npx --yes @notionhq/notion-mcp-server@latest"]
    }
  }
}
