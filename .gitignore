# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.op is the 1Password env-file template (op:// URIs only, no secrets) —
# see brikdesigns#253. Tracked so `op run --env-file=.env.op -- npm install`
# works for every contributor without out-of-band coordination.
!.env.op

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Local working data (Webflow CMS exports — re-download from Webflow as needed).
# Matches both the directory on the primary worktree and the symlink that
# `scripts/new-task.sh` creates inside task worktrees (no trailing slash).
/content/csv

# Supabase CLI internal state
/supabase/.temp/

# Playwright a11y outputs
/playwright-report/
/test-results/

# Playwright MCP scratch output (console logs, page snapshots) — never commit
.playwright-mcp/

# Git worktrees managed by new-task.sh (tracked as untracked by primary)
/.claude/worktrees/
