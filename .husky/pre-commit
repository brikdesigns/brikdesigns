# ── Token lint (invented tokens + service-family + property-family pairing) ──
# Mirrors brik-bds Rule 5 gate (brik-bds#578). Fails fast on wrong-family usage
# before the change reaches CI. Graceful skip if node_modules not installed.
if [ -f node_modules/.bin/node ] || command -v node >/dev/null 2>&1; then
  if [ -f scripts/lint-tokens.mjs ]; then
    echo "🔎 Running token lint..."
    if ! node scripts/lint-tokens.mjs; then
      echo ""
      echo "   Fix token violations above before committing."
      echo "   Escape hatch: add \`/* bds-lint-ignore token-family — <reason> */\` on the same line."
      exit 1
    fi
  fi
fi

# ── Heading title-case lint (marketing JSX) ──
# Stops sentence-case headings from regressing the #490 sweep. Canonical rule:
# brik-bds#910 (typography.mdx "Heading casing"). Heuristic — see the script for
# the allowlist + `/* lint-heading-case-ignore */` escape hatch (brikdesigns#491).
if [ -f node_modules/.bin/node ] || command -v node >/dev/null 2>&1; then
  if [ -f scripts/lint-heading-case.mjs ]; then
    echo "🔠 Running heading title-case lint..."
    if ! node scripts/lint-heading-case.mjs; then
      echo ""
      echo "   Title-case the heading above, or allowlist a genuine exception."
      exit 1
    fi
  fi
fi

# ── Image-budget lint (public/ asset weight) ──
# Stops oversized raster assets from regressing the #625 cleanup (8.3 MB → ~100 KB).
# Fails on any public/ image over the per-file budget. Standard + escape hatch:
# .claude/references/image-optimization.md and scripts/lint-images.mjs header.
if [ -f node_modules/.bin/node ] || command -v node >/dev/null 2>&1; then
  if [ -f scripts/lint-images.mjs ]; then
    echo "🖼  Running image-budget lint..."
    if ! node scripts/lint-images.mjs; then
      echo ""
      echo "   Compress/convert the image(s) above before committing."
      exit 1
    fi
  fi
fi

# ── Icon-collection drift (offline Phosphor subset) ──
# Keeps src/lib/icons.generated.json in sync with `ph:*` usage so a newly added
# icon can't silently fall through to the api.iconify.design CDN at runtime
# (brikdesigns#626). Also fails on a `ph:*` typo that doesn't exist in Phosphor.
# Fix: npm run gen:icons. Mirrors brik-bds#1002's gen-icon-collection gate.
if [ -f node_modules/.bin/node ] || command -v node >/dev/null 2>&1; then
  if [ -f scripts/gen-icon-collection.mjs ]; then
    echo "🎨 Running icon-collection drift check..."
    if ! node scripts/gen-icon-collection.mjs --check; then
      echo ""
      echo "   Run \`npm run gen:icons\` and stage src/lib/icons.generated.json."
      exit 1
    fi
  fi
fi

# ── Secret scan (gitleaks) ──
# Defense-in-depth for the secret-leak prevention layer. Mirrors the pattern
# used in brik-bds, brik-client-portal, renew-pms. Runs gitleaks on the staged
# diff; blocks commits containing patterns that match its built-in rules + any
# local .gitleaks.toml allowlist. Graceful skip if gitleaks isn't installed
# (CI / fresh machine).
#
# Canonical template: brik-bds/.husky/pre-commit. Layer-4 entry in
# brik-llm/operations/security/security-layers.md.
if command -v gitleaks >/dev/null 2>&1; then
  echo "🔍 Running gitleaks secret scan..."
  config_arg=""
  if [ -f .gitleaks.toml ]; then
    config_arg="--config .gitleaks.toml"
  fi
  if ! gitleaks protect --staged --redact --no-banner --verbose $config_arg; then
    echo ""
    echo "   Secret detected in staged changes. Move the value to ~/.secrets/<name>.env"
    echo "   and reference it via process.env.<NAME>. If false positive, add to .gitleaks.toml."
    exit 1
  fi
fi
